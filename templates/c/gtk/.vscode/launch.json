{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Build and debug GTK4 app",
			"type": "cppdbg",
			"request": "launch",
			"cwd": "${workspaceFolder}",
			"environment": [
				{
					"name": "GTK_DEBUG",
					"value": "interactive"
				}
			],
			"program": "${workspaceFolder}/builddir/src/{{FILENAME}}",
			"preLaunchTask": "Build GTK4 app"
		}

	]
}